# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# 프론트(Next.js) ISR 셸 on-demand 재검증 — 콘텐츠 변경 시 즉시 반영용.
# 미설정 시 재검증을 건너뜀(프론트 안전망 revalidate=5분으로 대체).
# URL은 프론트의 /api/revalidate, SECRET은 프론트 REVALIDATE_SECRET과 동일 값.
VITE_FRONT_REVALIDATE_URL=https://your-front-domain/api/revalidate
VITE_REVALIDATE_SECRET=your_shared_revalidate_secret
